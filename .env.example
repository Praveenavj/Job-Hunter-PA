# Server settings
HOST=0.0.0.0
PORT=8000

# OpenClaw / OpenAI-compatible chat completions API
OPENCLAW_API_URL=http://localhost:11434/v1/chat/completions
OPENCLAW_API_KEY=
OPENCLAW_MODEL=openclaw

# Jobs APIs
# Adzuna is used for location-based Singapore jobs
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Notion integration for /track
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Telegram bot
TELEGRAM_BOT_TOKEN=

# Telegram bot backend URL
BACKEND_BASE_URL=http://localhost:8000

# Gmail API (optional, used by /outreach send_now=true)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8000/oauth/gmail/callback

# App security / storage
APP_SECRET_KEY=change-me-in-production
SQLITE_DB_PATH=./data/job_hunter.db

ANTHROPIC_API_KEY=